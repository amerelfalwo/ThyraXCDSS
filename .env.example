# ── ThyraX CDSS v4.0.0 — Environment Variables ──

# Groq LLM (Primary — powers Agent + Clinical routing)
GROQ_API_KEY="gsk_your_groq_api_key_1_here"
GROQ_API_KEY_2="gsk_your_groq_api_key_2_here"
GROQ_API_KEY_3="gsk_your_groq_api_key_3_here"

# Internal Microservice Auth
INTERNAL_SERVICE_KEY="your-internal-service-key-here"

# PostgreSQL Database URL
# Supabase Database URL (Async Connection)
DATABASE_URL="postgresql+asyncpg://postgres:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres"

# ── Infrastructure (Added based on your request) ──

# Supabase Storage / Auth Settings
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-service-role-key"

# Redis Cache / Rate Limiting
REDIS_URL="redis://redis:6379/0"

# RabbitMQ / Celery Broker
RABBITMQ_URL="amqp://guest:guest@rabbitmq:5672//"
CELERY_BROKER_URL="amqp://guest:guest@rabbitmq:5672//"
CELERY_RESULT_BACKEND="redis://redis:6379/1"
